# BayHop runtime keys. Copy this file to `.env` and fill in the keys you have:
#
#   cp .env.example .env
#
# Then run with: flutter run -d <device> --dart-define-from-file=.env
# Keys are baked in at build time (String.fromEnvironment), so changing them
# requires a restart, not just a hot reload. Never commit real values — `.env`
# is gitignored.

# Required: the default model (Inception Labs Mercury 2) that powers both tabs.
# Get one at https://platform.inceptionlabs.ai/dashboard/api-keys
INCEPTION_API_KEY=

# Optional: enables Google Places cards in Explore (and Transit place search).
# Enable "Places API (New)" in Google Cloud and create a key.
GOOGLE_PLACES_API_KEY=

# Optional: lets the Flutter UI know a Google Maps SDK key is configured.
# Native Android/iOS and web each also need their platform key files below.
GOOGLE_MAPS_API_KEY=

# Optional: enables 511 SF Bay live departures beyond BART (Muni, Caltrain,
# AC Transit, ferries, …). Get a token at https://511.org/open-data/token
KEY_511=

# --- Optional overrides ---------------------------------------------------

# Your own BART API key. If unset, a public BART demo key is used, so BART
# real-time departures work out of the box.
# BART_API_KEY=

# Route BART requests through a proxy instead of api.bart.gov directly
# (useful to avoid CORS when running on the web).
# BART_PROXY_BASE_URL=

# Only needed if you swap the default model client for these providers.
# GEMINI_API_KEY=
# FEATHERLESS_API_KEY=
